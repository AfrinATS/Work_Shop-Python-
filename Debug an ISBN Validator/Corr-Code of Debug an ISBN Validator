def validate_isbn(isbn, length):
    if len(isbn) != length:
        print(f'ISBN-{length} code should be {length} digits long.')
        return
    
    # Main digits are first (length-1) characters, check digit is the last character
    main_digits = isbn[:length-1]
    given_check_digit = isbn[length-1]
    
    # Convert main digits to integers
    try:
        main_digits_list = [int(digit) for digit in main_digits]
    except ValueError:
        print('Invalid character was found.')
        return
    
    # Calculate expected check digit
    if length == 10:
        expected_check_digit = calculate_check_digit_10(main_digits_list)
    else:
        expected_check_digit = calculate_check_digit_13(main_digits_list)
    
    # Compare check digits
    if str(given_check_digit).upper() == expected_check_digit:
        print('Valid ISBN Code.')
    else:
        print('Invalid ISBN Code.')

def calculate_check_digit_10(main_digits_list):
    digits_sum = 0
    for index, digit in enumerate(main_digits_list):
        digits_sum += digit * (10 - index)
    result = 11 - (digits_sum % 11)
    
    if result == 11:
        return '0'
    elif result == 10:
        return 'X'
    else:
        return str(result)

def calculate_check_digit_13(main_digits_list):
    digits_sum = 0
    for index, digit in enumerate(main_digits_list):
        if index % 2 == 0:
            digits_sum += digit * 1
        else:
            digits_sum += digit * 3
    result = 10 - (digits_sum % 10)
    
    if result == 10:
        return '0'
    else:
        return str(result)

def main():
    user_input = input('Enter ISBN and length: ')
    values = user_input.split(',')
    
    # Check if comma-separated
    if len(values) != 2:
        print('Enter comma-separated values.')
        return
    
    isbn = values[0]
    
    # Check if length is a number
    try:
        length = int(values[1])
    except ValueError:
        print('Length must be a number.')
        return
    
    # Check if length is 10 or 13
    if length not in [10, 13]:
        print('Length should be 10 or 13.')
        return
    
    # Validate ISBN format
    if length == 10:
        # For ISBN-10: first 9 digits must be numbers, last can be number or X
        if len(isbn) == 10:
            if not (isbn[:9].isdigit() and (isbn[9].isdigit() or isbn[9].upper() == 'X')):
                print('Invalid character was found.')
                return
        else:
            print(f'ISBN-{length} code should be {length} digits long.')
            return
    else:  # length == 13
        # For ISBN-13: all 13 digits must be numbers
        if len(isbn) == 13:
            if not isbn.isdigit():
                print('Invalid character was found.')
                return
        else:
            print(f'ISBN-{length} code should be {length} digits long.')
            return
    
    # Validate the ISBN
    validate_isbn(isbn, length)

